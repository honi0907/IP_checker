<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="IPChecker.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:IPChecker.Helpers"
    xmlns:local="using:IPChecker"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:IPChecker.ViewModels"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:ControllerButtonBrushConverter x:Key="ControllerButtonBrushConverter" />
        <helpers:ControllerButtonForegroundConverter x:Key="ControllerButtonForegroundConverter" />
        <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="DetailToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailToolbarToggleSwitchStyle" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="2,0,0,0" />
            <Setter Property="Margin" Value="0,-8,0,-8" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid
        Padding="8,4,8,6"
        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid
            x:Name="MiniModePanel"
            AutomationProperties.AutomationId="MiniModePanel"
            Background="{x:Bind ViewModel.MiniDisplayedAdapter.RowBackground, Mode=OneWay}"
            CornerRadius="6"
            Padding="6,3,6,3"
            Visibility="{x:Bind ViewModel.MiniModeVisibility, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="MiniDragRegion"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                IsHitTestVisible="False" />

            <FontIcon
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                FontSize="15"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Glyph="{x:Bind ViewModel.MiniDisplayedAdapter.AdapterIconGlyph, Mode=OneWay}"
                ToolTipService.ToolTip="{x:Bind ViewModel.MiniDisplayedAdapter.Name, Mode=OneWay}" />

            <Grid
                Grid.Column="1"
                VerticalAlignment="Center"
                ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Spacing="0"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.MiniDisplayedAdapter.MiniWifiSsidStackVisibility, Mode=OneWay}">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="12"
                        LineHeight="14"
                        Text="{x:Bind ViewModel.MiniDisplayedAdapter.ShortName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        MaxWidth="88"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        FontSize="9"
                        LineHeight="11"
                        Text="{x:Bind ViewModel.MiniDisplayedAdapter.WifiSsid, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Spacing="0"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.MiniDisplayedAdapter.MiniUsbLanLinkStackVisibility, Mode=OneWay}">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="12"
                        LineHeight="14"
                        Text="{x:Bind ViewModel.MiniDisplayedAdapter.ShortName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="10"
                        LineHeight="12"
                        Text="{x:Bind ViewModel.MiniDisplayedAdapter.LinkStatusLabel, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <TextBlock
                    Grid.Column="0"
                    MaxWidth="72"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.MiniDisplayedAdapter.ShortName, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    Visibility="{x:Bind ViewModel.MiniDisplayedAdapter.MiniInlineShortNameVisibility, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="1"
                    MaxWidth="96"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.MiniDisplayedAdapter.LinkStatusLabel, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    Visibility="{x:Bind ViewModel.MiniDisplayedAdapter.MiniInlineLinkStatusVisibility, Mode=OneWay}" />
                <Grid
                    Grid.Column="2"
                    VerticalAlignment="Center">
                    <Button
                        MinWidth="0"
                        MinHeight="0"
                        Padding="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{x:Bind ViewModel.CopyPrimaryIpCommand}"
                        ToolTipService.ToolTip="クリックで IP をコピー"
                        Visibility="{x:Bind ViewModel.IsStartingUp, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="15"
                            FontWeight="SemiBold"
                            LineHeight="18"
                            Text="{x:Bind ViewModel.MiniDisplayedAdapter.IpAddressDisplay, Mode=OneWay}"
                            TextWrapping="NoWrap" />
                    </Button>
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6"
                        Visibility="{x:Bind ViewModel.IsStartingUp, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressRing
                            Width="12"
                            Height="12"
                            IsActive="True" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            Text="起動中..." />
                    </StackPanel>
                </Grid>
                <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    FontSize="8"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.MiniRotationIndicatorText, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.MiniRotationIndicatorVisibility, Mode=OneWay}" />
            </Grid>

            <Border
                Grid.Column="2"
                Margin="6,0,4,0"
                Padding="6,1"
                VerticalAlignment="Center"
                Background="{x:Bind ViewModel.MiniDisplayedAdapter.BadgeBackground, Mode=OneWay}"
                CornerRadius="4">
                <TextBlock
                    Foreground="{x:Bind ViewModel.MiniDisplayedAdapter.BadgeForeground, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.MiniDisplayedAdapter.AssignmentShortLabel, Mode=OneWay}" />
            </Border>

            <StackPanel
                Grid.Column="3"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="1">
                <Button
                    MinWidth="0"
                    MinHeight="0"
                    Padding="3"
                    Command="{x:Bind ViewModel.ToggleDisplayModeCommand}"
                    ToolTipService.ToolTip="詳細表示">
                    <FontIcon FontSize="11" Glyph="&#xE740;" />
                </Button>
                <Button
                    MinWidth="0"
                    MinHeight="0"
                    Padding="3"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    ToolTipService.ToolTip="更新">
                    <FontIcon FontSize="11" Glyph="&#xE72C;" />
                </Button>
                <Button
                    MinWidth="0"
                    MinHeight="0"
                    Padding="3"
                    Command="{x:Bind ViewModel.OpenControllerTestCommand}"
                    ToolTipService.ToolTip="コントローラテスト">
                    <FontIcon FontSize="11" Glyph="&#xE7FC;" />
                </Button>
                <Button
                    x:Name="MiniSettingsButton"
                    MinWidth="0"
                    MinHeight="0"
                    Padding="3"
                    Command="{x:Bind ViewModel.OpenSettingsCommand}"
                    ToolTipService.ToolTip="設定">
                    <FontIcon FontSize="11" Glyph="&#xE713;" />
                </Button>
                <Button
                    MinWidth="0"
                    MinHeight="0"
                    Padding="3"
                    Command="{x:Bind ViewModel.MinimizeToTrayCommand}"
                    ToolTipService.ToolTip="閉じる（トレイへ）">
                    <FontIcon FontSize="11" Glyph="&#xE8BB;" />
                </Button>
            </StackPanel>

            <Border
                Grid.Column="4"
                Margin="4,0,0,0"
                Padding="5,3"
                VerticalAlignment="Center"
                Background="{x:Bind ViewModel.BatteryContainerBackground, Mode=OneWay}"
                BorderBrush="{x:Bind ViewModel.BatteryContainerBorderBrush, Mode=OneWay}"
                BorderThickness="{x:Bind ViewModel.BatteryContainerBorderThickness, Mode=OneWay}"
                CornerRadius="6"
                Visibility="{x:Bind ViewModel.BatteryVisibility, Mode=OneWay}">
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="0">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="26"
                        Foreground="{x:Bind ViewModel.BatteryIconForeground, Mode=OneWay}"
                        Glyph="{x:Bind ViewModel.BatteryIconGlyph, Mode=OneWay}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.BatteryTooltipText, Mode=OneWay}" />
                    <FontIcon
                        HorizontalAlignment="Center"
                        Margin="0,-4,0,-2"
                        FontSize="11"
                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                        Glyph="&#xE823;"
                        ToolTipService.ToolTip="AC接続"
                        Visibility="{x:Bind ViewModel.BatteryPlugVisibility, Mode=OneWay}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Margin="0,-1,0,0"
                        FontSize="{x:Bind ViewModel.BatteryPercentFontSize, Mode=OneWay}"
                        FontWeight="{x:Bind ViewModel.BatteryPercentFontWeight, Mode=OneWay}"
                        Foreground="{x:Bind ViewModel.BatteryPercentForeground, Mode=OneWay}"
                        LineHeight="11"
                        Text="{x:Bind ViewModel.BatteryPercentText, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            x:Name="DetailModePanel"
            AutomationProperties.AutomationId="DetailModePanel"
            Margin="-8,-4,-8,-6"
            Visibility="{x:Bind ViewModel.DetailModeVisibility, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="DetailTopDragBar"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                    <TextBlock
                        Margin="12,0,8,0"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="ネットワーク IP 状況"
                        VerticalAlignment="Center" />
                </Border>

                <Button
                    Grid.Column="1"
                    MinWidth="36"
                    MinHeight="36"
                    Padding="8"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{x:Bind ViewModel.MinimizeToTrayCommand}"
                    ToolTipService.ToolTip="閉じる（トレイへ）">
                    <FontIcon FontSize="12" Glyph="&#xE8BB;" />
                </Button>
            </Grid>

            <Grid
                Grid.Row="1"
                Padding="8,8,8,6"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="0" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Spacing="2"
                    VerticalAlignment="Center">
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.UsbLanSummaryText, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.UsbLanDetailText, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Visibility="{x:Bind ViewModel.UsbLanDetailVisibility, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.LastUpdatedText, Mode=OneWay}"
                        TextWrapping="NoWrap" />
                </StackPanel>

                <Grid
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    ColumnSpacing="4"
                    RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource DetailToolbarIconButtonStyle}"
                        Command="{x:Bind ViewModel.ToggleDisplayModeCommand}"
                        ToolTipService.ToolTip="ミニ表示">
                        <FontIcon FontSize="11" Glyph="&#xE73F;" />
                    </Button>
                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        Width="44"
                        Height="24"
                        VerticalAlignment="Center">
                        <ToggleSwitch
                            Style="{StaticResource DetailToolbarToggleSwitchStyle}"
                            OffContent=""
                            OnContent=""
                            IsOn="{x:Bind ViewModel.IsAlwaysOnTop, Mode=TwoWay}"
                            ToolTipService.ToolTip="常に最前面に表示" />
                    </Border>
                    <Button
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource DetailToolbarIconButtonStyle}"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        ToolTipService.ToolTip="今すぐ更新">
                        <FontIcon FontSize="11" Glyph="&#xE72C;" />
                    </Button>
                    <Button
                        x:Name="DetailSettingsButton"
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource DetailToolbarIconButtonStyle}"
                        Command="{x:Bind ViewModel.OpenSettingsCommand}"
                        ToolTipService.ToolTip="設定">
                        <FontIcon FontSize="11" Glyph="&#xE713;" />
                    </Button>
                </Grid>
            </Grid>

            <ListView
                Grid.Row="1"
                IsItemClickEnabled="False"
                ItemsSource="{x:Bind ViewModel.Adapters, Mode=OneWay}"
                SelectionMode="None"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            MinHeight="100"
                            Padding="12"
                            Background="{Binding RowBackground}"
                            ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="20"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="{Binding AdapterIconGlyph}" />

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{Binding WifiSsid}"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{Binding DetailWifiSsidVisibility}" />
                                <TextBlock
                                    FontFamily="Consolas"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    Text="{Binding IpAddressDisplay}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{Binding LinkStatusLabel}"
                                    Visibility="{Binding LinkStatusVisibility}" />
                                <Border
                                    HorizontalAlignment="Left"
                                    Padding="8,2"
                                    Background="{Binding BadgeBackground}"
                                    CornerRadius="4">
                                    <TextBlock
                                        Foreground="{Binding BadgeForeground}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{Binding AssignmentLabel}" />
                                </Border>
                            </StackPanel>

                            <Button
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Click="OpenNetworkSharingCenterButton_Click"
                                Content="共有センター"
                                ToolTipService.ToolTip="ネットワークと共有センターを開く"
                                Visibility="{Binding CanOpenWindowsNetworkVisibility}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="有効なネットワークアダプタがありません"
                Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}" />

            <TextBlock
                Grid.Row="2"
                Margin="0,4,0,0"
                HorizontalAlignment="Right"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.AppVersionText, Mode=OneWay}" />
            </Grid>
        </Grid>

        <Grid
            x:Name="SettingsPanel"
            AutomationProperties.AutomationId="SettingsPanel"
            Margin="-8,-4,-8,-6"
            Visibility="{x:Bind ViewModel.SettingsVisibility, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="SettingsTopDragBar"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                    <TextBlock
                        Margin="12,0,8,0"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="設定"
                        VerticalAlignment="Center" />
                </Border>

                <Button
                    Grid.Column="1"
                    MinWidth="36"
                    MinHeight="36"
                    Padding="8"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="CloseSettingsButton_Click"
                    ToolTipService.ToolTip="閉じる">
                    <FontIcon FontSize="12" Glyph="&#xE8BB;" />
                </Button>
            </Grid>

            <ScrollViewer
                Grid.Row="1"
                Padding="8,8,8,6"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <ToggleSwitch
                        Header="Windows 起動時に自動開始"
                        IsOn="{x:Bind ViewModel.RunAtStartup, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="起動時はトレイのみ（ウィンドウ非表示）"
                        IsOn="{x:Bind ViewModel.StartInTrayOnly, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="仮想アダプタを表示"
                        IsOn="{x:Bind ViewModel.ShowVirtualAdapters, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="ミニ表示で交互に切り替え"
                        IsOn="{x:Bind ViewModel.MiniRotateAdapters, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="常に最前面に表示"
                        IsOn="{x:Bind ViewModel.IsAlwaysOnTop, Mode=TwoWay}" />

                    <ToggleSwitch
                        Header="トレイ常駐時は省エネモード"
                        IsOn="{x:Bind ViewModel.EnableEfficiencyMode, Mode=TwoWay}" />

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="トレイアイコン: ● 青=自動 / ■ 橙=手動 / ○ 灰=未取得" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="ウィンドウ位置" />
                        <ComboBox
                            x:Name="WindowAnchorComboBox"
                            HorizontalAlignment="Stretch"
                            DisplayMemberPath="Label"
                            ItemsSource="{x:Bind ViewModel.WindowAnchorOptions, Mode=OneWay}"
                            SelectionChanged="WindowAnchorComboBox_SelectionChanged" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="起動遅延（秒）" />
                        <NumberBox
                            Maximum="120"
                            Minimum="0"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.StartupDelaySeconds, Mode=TwoWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="ログオン後、監視開始まで待つ秒数（0〜120）" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="アプリの更新" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="GitHub のリリースを確認します（24時間に1回）"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Text="{x:Bind ViewModel.UpdateStatusText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                Content="更新を確認"
                                IsEnabled="{x:Bind ViewModel.CanCheckForUpdates, Mode=OneWay}" />
                            <Button
                                Command="{x:Bind ViewModel.OpenUpdateDownloadCommand}"
                                Content="ダウンロード"
                                Visibility="{x:Bind ViewModel.UpdateDownloadVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.AppVersionText, Mode=OneWay}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid
            x:Name="ControllerTestPanel"
            AutomationProperties.AutomationId="ControllerTestPanel"
            Margin="-8,-4,-8,-6"
            Padding="8,4,8,6"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            RowSpacing="8"
            Visibility="{x:Bind ViewModel.ControllerTestVisibility, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid MinHeight="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="ControllerTestTitleDragRegion"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                    <TextBlock
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="コントローラテスト"
                        VerticalAlignment="Center" />
                </Border>

                <Button
                    Grid.Column="1"
                    MinWidth="0"
                    MinHeight="0"
                    Padding="3"
                    VerticalAlignment="Center"
                    Click="CloseControllerTestButton_Click"
                    ToolTipService.ToolTip="閉じる">
                    <FontIcon FontSize="11" Glyph="&#xE8BB;" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.ControllerTest.DeviceName, Mode=OneWay}" />

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="コントローラが見つかりません。USB で接続してから再度お試しください。"
                        Visibility="{x:Bind ViewModel.ControllerTest.NotConnectedVisibility, Mode=OneWay}" />

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.ControllerTest.ConnectedVisibility, Mode=OneWay}">
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="ボタン" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ControllerTest.Buttons, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid MaximumRowsOrColumns="8" Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ControllerButtonItemViewModel">
                                    <Border
                                        Width="36"
                                        Height="36"
                                        Margin="3"
                                        Background="{x:Bind IsPressed, Mode=OneWay, Converter={StaticResource ControllerButtonBrushConverter}}"
                                        CornerRadius="18"
                                        Opacity="{x:Bind IsAvailable, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{x:Bind IsPressed, Mode=OneWay, Converter={StaticResource ControllerButtonForegroundConverter}}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind Number}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
